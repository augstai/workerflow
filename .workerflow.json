{
  "schemaVersion": 1,
  "agent": "codex",
  "worktree": true,
  "desktop": {
    "hotkey": "Alt+Space",
    "hotkeyMode": "toggle"
  },
  "transcription": {
    "provider": "mock",
    "model": "gpt-4o-mini-transcribe"
  },
  "adapters": {
    "codex": {
      "sandbox": "workspace-write",
      "approvalPolicy": "never",
      "json": false,
      "timeoutMs": 1800000
    },
    "claude": {
      "permissionMode": "dontAsk",
      "outputFormat": "json",
      "timeoutMs": 1800000
    }
  },
  "commands": {
    "test": "pnpm test",
    "build": "",
    "lint": "pnpm lint"
  },
  "safePaths": [
    "app",
    "src",
    "components",
    "packages",
    "tests"
  ],
  "denyPaths": [
    ".env",
    ".env.*",
    "prisma/schema.prisma",
    "migrations",
    "secrets",
    "credentials"
  ]
}
