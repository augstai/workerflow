# Copy this file to .env while developing Workerflow from the repo, or to
# ~/.workerflow/.env for a desktop-wide local setup.
#
# Never commit real keys.

# Recommended first provider for Workerflow voice commands.
WORKERFLOW_TRANSCRIPTION_PROVIDER=azure-openai

# Azure OpenAI transcription deployment.
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_TRANSCRIPTION_DEPLOYMENT=YOUR_TRANSCRIPTION_DEPLOYMENT_NAME
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_KEY

# Optional direct OpenAI fallback.
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Optional ElevenLabs fallback.
ELEVENLABS_API_KEY=
ELEVENLABS_TRANSCRIPTION_MODEL=scribe_v2
